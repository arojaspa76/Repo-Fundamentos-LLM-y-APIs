# ============================================================
# Fundamentos de Arquitectura LLM — Sesión 2
# Variables de Entorno — NUNCA commitear .env al repositorio
# ============================================================

# === Tema 1: Ollama Local ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=60

# === Tema 2: Azure AI Foundry ===
# Obtener desde: https://ai.azure.com → tu proyecto → Deployments
AZURE_AI_ENDPOINT=https://<tu-proyecto>.services.ai.azure.com/models
AZURE_AI_KEY=<tu-api-key-de-azure-ai-foundry>
AZURE_AI_MODEL=gpt-4o                     # Nombre del deployment en Foundry
AZURE_AI_API_VERSION=2024-12-01-preview

# === Azure — Autenticación alternativa (para producción) ===
# Usar DefaultAzureCredential en lugar de API Key
AZURE_USE_MANAGED_IDENTITY=false
AZURE_CLIENT_ID=                          # Solo si usas Service Principal
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# === Azure — Recursos adicionales ===
AZURE_RESOURCE_GROUP=rg-llm-latam
AZURE_LOCATION=eastus2
AZURE_SUBSCRIPTION_ID=

# === FastAPI ===
APP_ENV=development
LOG_LEVEL=info
PORT_LOCAL=8001
PORT_AZURE=8002

# === Redis (Caché — opcional) ===
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# === Prometheus ===
METRICS_ENABLED=true
METRICS_PORT=8080

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

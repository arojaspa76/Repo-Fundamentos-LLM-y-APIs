# ============================================================
# Fundamentos de Arquitectura LLM — Variables de Entorno
# Copiar a .env y completar con tus credenciales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# === OpenAI ===
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_ORG_ID=org-...optional...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-20241022

# === Google (Gemini) ===
GOOGLE_API_KEY=AI...your-key-here...
GOOGLE_DEFAULT_MODEL=gemini-1.5-flash

# === Azure OpenAI (opcional) ===
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# === Ollama (local) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# === FastAPI ===
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=info
